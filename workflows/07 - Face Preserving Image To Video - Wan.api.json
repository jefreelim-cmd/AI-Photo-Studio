{
  "1": {
    "inputs": {
      "image": "Original.jpg"
    },
    "_meta": {
      "title": "Load source image"
    },
    "class_type": "LoadImage"
  },
  "2": {
    "inputs": {
      "model": "wan2.2_ti2v_5B_fp16.safetensors",
      "base_precision": "fp16",
      "load_device": "offload_device",
      "quantization": "disabled"
    },
    "_meta": {
      "title": "Load Wan 2.2 image-to-video model"
    },
    "class_type": "WanVideoModelLoader"
  },
  "3": {
    "inputs": {
      "precision": "bf16",
      "use_cpu_cache": false,
      "model_name": "wan2.2_vae.safetensors",
      "verbose": false
    },
    "_meta": {
      "title": "Load Wan 2.2 VAE"
    },
    "class_type": "WanVideoVAELoader"
  },
  "4": {
    "inputs": {
      "precision": "bf16",
      "load_device": "offload_device",
      "model_name": "nsfw_wan_umt5-xxl_fp8_scaled.safetensors",
      "quantization": "disabled"
    },
    "_meta": {
      "title": "Load Wan T5 text encoder"
    },
    "class_type": "LoadWanVideoT5TextEncoder"
  },
  "5": {
    "inputs": {
      "t5": [
        "4",
        0
      ],
      "force_offload": true,
      "device": "gpu",
      "model_to_offload": [
        "2",
        0
      ],
      "positive_prompt": "A subtle, photorealistic image-to-video shot based on the supplied source photograph. Preserve every person's exact identity, face, facial structure, age, skin tone, hairstyle, clothing, body proportions, and natural likeness throughout the entire clip. Keep the initial composition and scene consistent. Add only gentle realistic motion: natural blinking, small head movement, relaxed breathing, slight fabric and background movement, and a very slow stable camera drift. Maintain consistent lighting, perspective, photographic texture, and temporal coherence.",
      "negative_prompt": "different person, changed face, face swap, facial distortion, identity drift, de-aged face, beautified face, warped hands, extra limbs, flicker, frame-to-frame inconsistency, camera shake, text, watermark, cartoon, CGI, painting, blur"
    },
    "_meta": {
      "title": "Face-preserving motion prompt"
    },
    "class_type": "WanVideoTextEncode"
  },
  "6": {
    "inputs": {
      "value": 5
    },
    "_meta": {
      "title": "Video duration (seconds)"
    },
    "class_type": "PrimitiveInt"
  },
  "7": {
    "inputs": {
      "expression": "a * 16 + 1",
      "a": [
        "6",
        0
      ]
    },
    "_meta": {
      "title": "Frames (16 fps)"
    },
    "class_type": "MathExpression|pysssss"
  },
  "8": {
    "inputs": {
      "height": 832,
      "vae": [
        "3",
        0
      ],
      "width": 480,
      "force_offload": true,
      "start_latent_strength": 1.0,
      "num_frames": [
        "7",
        0
      ],
      "noise_aug_strength": 0.02,
      "start_image": [
        "1",
        0
      ],
      "end_latent_strength": 1.0
    },
    "_meta": {
      "title": "Encode image reference"
    },
    "class_type": "WanVideoImageToVideoEncode"
  },
  "9": {
    "inputs": {
      "riflex_freq_index": 0,
      "seed": 123456789,
      "text_embeds": [
        "5",
        0
      ],
      "force_offload": true,
      "model": [
        "2",
        0
      ],
      "steps": 20,
      "cfg": 5.0,
      "image_embeds": [
        "8",
        0
      ],
      "shift": 5.0,
      "scheduler": "unipc"
    },
    "_meta": {
      "title": "Generate face-preserving video"
    },
    "class_type": "WanVideoSampler"
  },
  "10": {
    "inputs": {
      "tile_stride_x": 144,
      "tile_y": 272,
      "samples": [
        "9",
        0
      ],
      "vae": [
        "3",
        0
      ],
      "tile_x": 272,
      "tile_stride_y": 128,
      "enable_vae_tiling": false
    },
    "_meta": {
      "title": "Decode video frames"
    },
    "class_type": "WanVideoDecode"
  },
  "11": {
    "inputs": {
      "frame_rate": 16,
      "images": [
        "10",
        0
      ],
      "pingpong": false,
      "loop_count": 0,
      "save_output": true,
      "format": "video/h264-mp4",
      "filename_prefix": "face_preserving_video"
    },
    "_meta": {
      "title": "Save MP4 video"
    },
    "class_type": "VHS_VideoCombine"
  }
}
